# ── Groq ──────────────────────────────────────────────────────
GROQ_API_KEY=gsk_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ── LangFuse ──────────────────────────────────────────────────
LANGFUSE_PUBLIC_KEY=pk-lf-xxxxxxxxxxxxxxxxxxxxxxxxx
LANGFUSE_SECRET_KEY=sk-lf-xxxxxxxxxxxxxxxxxxxxxxxxx
LANGFUSE_HOST=https://cloud.langfuse.com

# ── App ───────────────────────────────────────────────────────
APP_ENV=development
LOG_LEVEL=INFO
DEFAULT_MODEL=groq/llama-3.3-70b-versatile
# CORS: dùng "*" cho dev; production điền domain cụ thể, phân tách bằng dấu phẩy
CORS_ORIGINS=*
# Số lượt hội thoại tối đa giữ trong history (1 lượt = 1 user + 1 assistant)
MAX_HISTORY_TURNS=20
# Retry: số lần thử lại tối đa và base delay (giây) — backoff = delay * 2^(attempt-1)
MAX_RETRIES=3
RETRY_DELAY_S=1.0
